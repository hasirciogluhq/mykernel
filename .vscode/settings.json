{
  "clangd.arguments": [
    "--compile-commands-dir=${workspaceFolder}",
    "--background-index"
  ],
  "C_Cpp.default.configurationProvider": "",
  "C_Cpp.default.cStandard": "c11",
  "C_Cpp.default.intelliSenseMode": "linux-gcc-x86",
  "C_Cpp.default.includePath": [
    "${workspaceFolder}/include"
  ],
  "C_Cpp.default.defines": [
    "__i386__",
    "__i386",
    "__freestanding__"
  ],
  "C_Cpp.default.compilerArgs": [
    "--target=i386-none-elf",
    "-std=c11",
    "-ffreestanding",
    "-fno-builtin",
    "-fno-stack-protector",
    "-fno-pic",
    "-nostdlib",
    "-I${workspaceFolder}/include"
  ],
  "C_Cpp.default.compilerPath": "/opt/homebrew/opt/llvm/bin/clang",
  "C_Cpp.errorSquiggles": "enabled",
  "C_Cpp.intelliSenseEngine": "default",
  "files.associations": {
    "*.h": "c",
    "*.c": "c"
  },
  "C_Cpp_Runner.cCompilerPath": "/opt/homebrew/opt/llvm/bin/clang",
  "C_Cpp_Runner.cppCompilerPath": "/opt/homebrew/opt/llvm/bin/clang++",
  "C_Cpp_Runner.debuggerPath": "lldb",
  "C_Cpp_Runner.cStandard": "c11",
  "C_Cpp_Runner.cppStandard": "c++17",
  "C_Cpp_Runner.useMsvc": false,
  "C_Cpp_Runner.enableWarnings": true,
  "C_Cpp_Runner.warningsAsError": false,
  "C_Cpp_Runner.compilerArgs": [
    "--target=i386-none-elf",
    "-ffreestanding",
    "-fno-builtin",
    "-nostdlib"
  ],
  "C_Cpp_Runner.linkerArgs": [],
  "C_Cpp_Runner.includePaths": [
    "${workspaceFolder}/include"
  ],
  "C_Cpp_Runner.includeSearch": [
    "include/**",
    "src/**"
  ],
  "C_Cpp_Runner.excludeSearch": [
    "**/build",
    "**/build/**",
    "**/.*",
    "**/.*/**",
    "**/.vscode",
    "**/.vscode/**"
  ],
  "C_Cpp_Runner.useAddressSanitizer": false,
  "C_Cpp_Runner.useUndefinedSanitizer": false,
  "C_Cpp_Runner.useLeakSanitizer": false,
  "C_Cpp_Runner.showCompilationTime": false,
  "C_Cpp_Runner.useLinkTimeOptimization": false,
  "C_Cpp_Runner.msvcSecureNoWarnings": false,
  "C_Cpp_Runner.msvcBatchPath": ""
}
